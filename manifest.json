{
  "manifest_version": 3,
  "name": "ScreenSense Zoom",
  "description": "Baseline Chrome extension for ScreenSense Zoom.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ScreenSense Zoom",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  }
}
